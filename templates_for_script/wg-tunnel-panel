[Interface]
PrivateKey = $WG_TUNNEL_PIK
Address = 10.9.0.1/24
ListenPort = 51830
PostUp = sysctl -w net.ipv4.ip_forward=1; iptables -A FORWARD -i wg-tunnel -o $DEFAULT_IFACE -j ACCEPT; iptables -A FORWARD -i $DEFAULT_IFACE -o wg-tunnel -m state --state RELATED,ESTABLISHED -j ACCEPT; iptables -t nat -A POSTROUTING -s 10.8.0.0/24 -o $DEFAULT_IFACE -j MASQUERADE
PostDown = iptables -D FORWARD -i wg-tunnel -o $DEFAULT_IFACE -j ACCEPT; iptables -D FORWARD -i $DEFAULT_IFACE -o wg-tunnel -m state --state RELATED,ESTABLISHED -j ACCEPT; iptables -t nat -D POSTROUTING -s 10.8.0.0/24 -o $DEFAULT_IFACE -j MASQUERADE

