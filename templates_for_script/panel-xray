{
  "log": {"loglevel": "warning"},
  "inbounds": [{
    "tag": "VLESS_XHTTP_REALITY",
    "listen": "0.0.0.0",
    "port": 49321,
    "protocol": "vless",
    "settings": {
      "clients": [{"id": "$UUID_LINK"}],
      "decryption": "none"
    },
    "streamSettings": {
      "network": "xhttp",
      "security": "reality",
      "xhttpSettings": {
        "path": "/$XHTTP_PATH",
        "extra": {"xPaddingBytes": "300-2000"}
      },
      "realitySettings": {
        "dest": "127.0.0.1:4123",
        "xver": 1,
        "serverNames": ["$VPS1_DOMAIN"],
        "privateKey": "$XRAY_PIK",
        "publicKey": "$XRAY_PBK",
        "shortIds": [$SHORT_IDS]
      }
    },
    "sniffing": {
      "enabled": true,
      "destOverride": ["http", "tls"],
      "routeOnly": true
    }
  }],
  "outbounds": [
    {"protocol": "freedom", "tag": "direct", "settings": {"domainStrategy": "UseIPv4"}},
    {"protocol": "blackhole", "tag": "block"}
  ],
  "routing": {
    "rules": [{"protocol": "bittorrent", "outboundTag": "block"}],
    "domainStrategy": "IPIfNonMatch"
  },
  "dns": {
    "servers": ["1.1.1.1", "8.8.8.8"],
    "queryStrategy": "UseIPv4"
  }
}
