services:
  angie:
    image: docker.angie.software/angie:minimal
    container_name: angie
    restart: always
    network_mode: host
    volumes:
      - angie-data:/var/lib/angie
      - ./angie.conf:/etc/angie/angie.conf
      - ./index.html:/tmp/index.html
  marzban:
    image: gozargah/marzban:latest
    container_name: marzban
    restart: always
    env_file: ./marzban/.env
    network_mode: host
    volumes:
      - ./marzban/xray_config.json:/code/xray_config.json
      - ./xray-core:/code/xray-core
      - ./marzban_lib:/var/lib/marzban

volumes:
  angie-data:
    driver: local
    external: false
    name: angie-data
